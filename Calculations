//Height Calculations
float getHeight(float Airpressure) {
  Pressure = Airpressure;
  Pressure = Pressure / 100;
  Pressure = Pressure / 1013.25;
  Pressure = pow(Pressure, 0.190284);
  Pressure = 1 - Pressure;
  Height = Pressure * 145366.45;

  return Height;
}

