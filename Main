// ↓ IMPORTANT CODE STARTS HERE!!! ↓
void setup() {
  Serial.begin(115200);
  Serial.println("Code is running young children");

  BarometerSetup();  // Running the Setup part of the barometer code
  ICMSetup(); // Running the Setup part of the ICM code
}

void loop() {
  BarometerLoop(); // running the Loop part of the barometer code
  ICMLoop(); // running the Loop part of the ICM code

  Height = getHeight(Pressure);
  //get
}
